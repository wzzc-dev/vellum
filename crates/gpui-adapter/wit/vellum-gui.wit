package vellum:gui@0.1.0;

interface types {
  record color {
    r: f32,
    g: f32,
    b: f32,
    a: f32,
  }

  record point {
    x: f32,
    y: f32,
  }

  record size {
    width: f32,
    height: f32,
  }

  record rect {
    x: f32,
    y: f32,
    width: f32,
    height: f32,
  }

  record edge-insets {
    top: f32,
    right: f32,
    bottom: f32,
    left: f32,
  }

  enum alignment {
    start,
    center,
    end,
    stretch,
    space-between,
    space-around,
    space-evenly,
  }

  enum cross-alignment {
    start,
    center,
    end,
    stretch,
  }

  enum cursor-shape {
    default,
    pointer,
    text,
    wait,
    crosshair,
    progress,
    help,
    move,
    not-allowed,
    no-drop,
    grab,
    grabbing,
  }

  enum overflow {
    visible,
    hidden,
    scroll,
    auto,
  }

  record border {
    width: f32,
    style: border-style,
    color: color,
  }

  enum border-style {
    none,
    solid,
    dashed,
    dotted,
    double,
  }

  record box-shadow {
    offset-x: f32,
    offset-y: f32,
    blur-radius: f32,
    spread-radius: f32,
    color: color,
  }

  enum wrap {
    no-wrap,
    wrap,
    wrap-reverse,
  }

  enum visibility {
    visible,
    hidden,
    collapse,
  }

  record transform {
    translate-x: f32,
    translate-y: f32,
    scale-x: f32,
    scale-y: f32,
    rotation: f32,
  }

  variant pointer-events {
    none,
    all,
    auto,
  }

  record widget {
    id: string,
    widget-type: string,
  }
}

interface window {
  use types.{color, cursor-shape, size, point};

  record window-options {
    title: string,
    width: u32,
    height: u32,
    min-width: u32,
    min-height: u32,
    max-width: u32,
    max-height: u32,
    resizable: bool,
    decorated: bool,
    transparent: bool,
    always-on-top: bool,
    center: bool,
  }

  create-window: func(options: window-options) -> option<u32>;
  close-window: func(id: u32);
  set-title: func(id: u32, title: string);
  get-title: func(id: u32) -> string;
  minimize: func(id: u32);
  maximize: func(id: u32);
  unmaximize: func(id: u32);
  is-maximized: func(id: u32) -> bool;
  restore: func(id: u32);
  show: func(id: u32);
  hide: func(id: u32);
  is-visible: func(id: u32) -> bool;
  set-size: func(id: u32, width: u32, height: u32);
  get-size: func(id: u32) -> size;
  set-position: func(id: u32, position: point);
  get-position: func(id: u32) -> point;
  set-fullscreen: func(id: u32, fullscreen: bool);
  is-fullscreen: func(id: u32) -> bool;
  set-always-on-top: func(id: u32, always-on-top: bool);
  set-cursor: func(id: u32, shape: cursor-shape);
  set-cursor-position: func(id: u32, position: point);
  request-user-attention: func(id: u32);
  start-dragging: func(id: u32);
}

interface widget {
  use types.{color, cursor-shape, visibility, box-shadow, pointer-events, transform, size, point, rect, edge-insets, alignment, cross-alignment, wrap, border, overflow, widget};

  record widget-layout {
    display: widget-display,
    flex-direction: flex-direction,
    flex-wrap: wrap,
    justify-content: alignment,
    align-items: cross-alignment,
    align-content: alignment,
    gap: f32,
    row-gap: f32,
    column-gap: f32,
    position: widget-position,
    min-width: option<f32>,
    max-width: option<f32>,
    min-height: option<f32>,
    max-height: option<f32>,
    overflow-x: overflow,
    overflow-y: overflow,
  }

  enum widget-display {
    none,
    flex,
    block,
    inline,
    inline-block,
    inline-flex,
    grid,
  }

  enum flex-direction {
    row,
    row-reverse,
    column,
    column-reverse,
  }

  enum widget-position {
    static-position,
    relative,
    absolute,
    fixed,
    sticky,
  }

  create-widget: func(widget-type: string) -> widget;
  destroy-widget: func(id: string);
  mount-widget: func(id: string, parent-id: string);
  unmount-widget: func(id: string);

  set-widget-layout: func(id: string, layout: widget-layout);
  get-widget-layout: func(id: string) -> widget-layout;

  set-widget-size: func(id: string, width: f32, height: f32);
  get-widget-size: func(id: string) -> size;

  set-widget-position: func(id: string, x: f32, y: f32);
  get-widget-position: func(id: string) -> point;

  set-widget-padding: func(id: string, insets: edge-insets);
  set-widget-margin: func(id: string, insets: edge-insets);
  set-widget-border: func(id: string, border: border);
  set-widget-border-radius: func(id: string, radius: f32);
  set-widget-background: func(id: string, color: color);
  set-widget-opacity: func(id: string, opacity: f32);
  set-widget-visibility: func(id: string, visibility: visibility);
  set-widget-z-index: func(id: string, z-index: s32);
  set-widget-cursor: func(id: string, cursor: cursor-shape);

  set-widget-transform: func(id: string, transform: transform);

  set-widget-shadow: func(id: string, shadow: option<box-shadow>);

  set-widget-pointer-events: func(id: string, events: pointer-events);

  mark-needs-layout: func(id: string);
  mark-needs-paint: func(id: string);

  get-widget-bounds: func(id: string) -> rect;
  get-widget-global-bounds: func(id: string) -> rect;

  set-widget-clip: func(id: string, clip: bool, bounds: rect);

  focus-widget: func(id: string);
  blur-widget: func(id: string);
  has-focus: func(id: string) -> bool;
}

world vellum-gui {
  import types;
  import window;
  import widget;
}
