#doc(hidden)
pub fn wasmExportShutdown() -> Int {

      let (result) : (Result[Unit, @types.AppError]) = shutdown();
      let return_area = mbt_ffi_malloc(12)

      match result {
            Ok(_payload) => {
                  mbt_ffi_store8((return_area) + 0, (0))

                  ()
            }
            Err(payload0) => {
                  mbt_ffi_store8((return_area) + 0, (1))

                  let ptr = mbt_ffi_str2ptr((payload0).message)
                  mbt_ffi_store32((return_area) + 8, (payload0).message.length())
                  mbt_ffi_store32((return_area) + 4, ptr)

                  ()
            }
      }
      let ret = return_area
      return ret

}

