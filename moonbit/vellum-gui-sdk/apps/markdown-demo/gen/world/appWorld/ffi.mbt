                                          mbt_ffi_store32((iter_base) + 0, ptr45)

                                          let ptr46 = mbt_ffi_str2ptr((iter_elem).label)
                                          mbt_ffi_store32((iter_base) + 12, (iter_elem).label.length())
                                          mbt_ffi_store32((iter_base) + 8, ptr46)
                                          mbt_ffi_store32((iter_base) + 16, ((iter_elem).child).reinterpret_as_int())

                                    }
                                    mbt_ffi_store32((iter_base) + 20, ((payload44).tabs).length())
                                    mbt_ffi_store32((iter_base) + 16, address)

                                    ()
                              }
                              SplitView(payload48) => {
                                    mbt_ffi_store8((iter_base) + 8, (7))
                                    mbt_ffi_store8((iter_base) + 12, (payload48).axis.ordinal())
                                    mbt_ffi_storef32((iter_base) + 16, (payload48).ratio)

                                    ()
                              }
                              ScrollView(payload49) => {
                                    mbt_ffi_store8((iter_base) + 8, (8))
                                    mbt_ffi_store8((iter_base) + 12, (payload49).axis.ordinal())

                                    ()
                              }
                              NativeView(payload50) => {
                                    mbt_ffi_store8((iter_base) + 8, (9))

                                    let ptr51 = mbt_ffi_str2ptr((payload50).kind)
                                    mbt_ffi_store32((iter_base) + 16, (payload50).kind.length())
                                    mbt_ffi_store32((iter_base) + 12, ptr51)

                                    let address54 = mbt_ffi_malloc(((payload50).props).length() * 16);
                                    for index55 = 0; index55 < ((payload50).props).length(); index55 = index55 + 1 {
                                          let iter_elem : @types.Property = ((payload50).props)[(index55)]
                                          let iter_base = address54 + (index55 * 16);

                                          let ptr52 = mbt_ffi_str2ptr((iter_elem).name)
                                          mbt_ffi_store32((iter_base) + 4, (iter_elem).name.length())
                                          mbt_ffi_store32((iter_base) + 0, ptr52)

                                          let ptr53 = mbt_ffi_str2ptr((iter_elem).value)
                                          mbt_ffi_store32((iter_base) + 12, (iter_elem).value.length())
                                          mbt_ffi_store32((iter_base) + 8, ptr53)

                                    }
                                    mbt_ffi_store32((iter_base) + 24, ((payload50).props).length())
                                    mbt_ffi_store32((iter_base) + 20, address54)

                                    ()
                              }
                        }

                        let ptr56 = mbt_ffi_uint_array2ptr((iter_elem).children)

                        mbt_ffi_store32((iter_base) + 52, (iter_elem).children.length())
                        mbt_ffi_store32((iter_base) + 48, ptr56)

                  }
                  mbt_ffi_store32((return_area) + 12, ((payload).nodes).length())
                  mbt_ffi_store32((return_area) + 8, address57)

                  ()
            }
            Err(payload59) => {
                  mbt_ffi_store8((return_area) + 0, (1))

                  let ptr60 = mbt_ffi_str2ptr((payload59).message)
                  mbt_ffi_store32((return_area) + 8, (payload59).message.length())
                  mbt_ffi_store32((return_area) + 4, ptr60)

                  ()
            }
      }
      let ret = return_area
      return ret

}

#doc(hidden)
pub fn wasmExportUpdatePostReturn(p0 : Int) -> Unit {

      match (mbt_ffi_load8_u((p0) + 0)) {
            0 => {

                  for index1 = 0; index1 < (mbt_ffi_load32((p0) + 12)); index1 = index1 + 1 {
